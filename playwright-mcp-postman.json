    {
      "name": "Workflow Example",
      "item": [
        {
          "name": "1. Start Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.status === 'success') pm.collectionVariables.set(\"sessionId\", jsonData.data.sessionId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\"viewport\": {\"width\": 1280, \"height\": 720}}"
            },
            "url": { "raw": "{{baseUrl}}/session/start", "host": ["{{baseUrl}}"], "path": ["session", "start"] }
          }
        },
        {
          "name": "2. Navigate",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\"tool\":\"navigate\",\"sessionId\":\"{{sessionId}}\",\"args\":{\"url\":\"https://example.com\"}}"
            },
            "url": { "raw": "{{baseUrl}}/tool", "host": ["{{baseUrl}}"], "path": ["tool"] }
          }
        },
        {
          "name": "3. Click Link",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\"tool\":\"click\",\"sessionId\":\"{{sessionId}}\",\"args\":{\"selector\":\"a\"}}"
            },
            "url": { "raw": "{{baseUrl}}/tool", "host": ["{{baseUrl}}"], "path": ["tool"] }
          }
        },
        {
          "name": "4. Close Session",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\"sessionId\":\"{{sessionId}}\"}"
            },
            "url": { "raw": "{{baseUrl}}/session/close", "host": ["{{baseUrl}}"], "path": ["session", "close"] }
          }
        }
      ]
    }
