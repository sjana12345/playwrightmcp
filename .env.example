# Server Configuration
PORT=3002
HOST=0.0.0.0

# Browser Configuration
BROWSER_HEADLESS=true
DEFAULT_TIMEOUT=30000
RETRY_ATTEMPTS=3
RETRY_DELAY=1000
SCREENSHOT_ON_FAILURE=true
TRACING_ENABLED=false
VIDEO_RECORDING=false

# Session Configuration
MAX_CONCURRENT_SESSIONS=10
SESSION_IDLE_TIMEOUT=300000
REQUEST_TIMEOUT=60000

# Zephyr Scale Configuration
# Get your API token from Zephyr Scale -> API Access Token
ZEPHYR_API_TOKEN=your_token_here
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2

# AI Self-Healing Configuration
SELF_HEALING_ENABLED=false
AI_API_KEY=your_openai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Database Configuration (PostgreSQL)
DB_HOST=192.168.2.15
DB_PORT=5432
DB_NAME=unizap_users
DB_USER=dev_admin
DB_PASSWORD=your_password_here
